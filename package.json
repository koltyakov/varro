{
  "name": "varro",
  "displayName": "Varro",
  "description": "OpenCode with real project context, agent control, and sessions that stay with your code.",
  "version": "0.6.0",
  "publisher": "koltyakov",
  "repository": "https://github.com/koltyakov/varro",
  "license": "MIT",
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0",
    "vscode": "^1.91.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages",
    "Machine Learning"
  ],
  "keywords": [
    "ai",
    "chat",
    "opencode",
    "agent"
  ],
  "main": "./dist/extension/extension.js",
  "icon": "assets/icon.png",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "varro",
          "title": "Varro",
          "icon": "assets/icon.png"
        }
      ]
    },
    "views": {
      "varro": [
        {
          "icon": "assets/icon.png",
          "type": "webview",
          "id": "varro.chat",
          "name": "Varro"
        }
      ]
    },
    "commands": [
      {
        "command": "varro.chat.newSession",
        "title": "Varro: New Session"
      },
      {
        "command": "varro.chat.abort",
        "title": "Varro: Abort Session"
      },
      {
        "command": "varro.server.restart",
        "title": "Varro: Restart Server"
      },
      {
        "command": "varro.chat.addToContext",
        "title": "Varro: Add to Context"
      },
      {
        "command": "varro.chat.addSelectionToContext",
        "title": "Varro: Add to Context"
      },
      {
        "command": "varro.chat.addTerminalSelectionToContext",
        "title": "Varro: Add to Context"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "varro.chat.addToContext",
          "group": "z_varro"
        }
      ],
      "editor/context": [
        {
          "command": "varro.chat.addSelectionToContext",
          "when": "editorHasSelection && !editorReadonly",
          "group": "z_varro"
        }
      ],
      "terminal/context": [
        {
          "command": "varro.chat.addTerminalSelectionToContext",
          "when": "terminalTextSelected",
          "group": "z_varro"
        }
      ],
      "commandPalette": [
        {
          "command": "varro.chat.addToContext",
          "when": "false"
        },
        {
          "command": "varro.chat.addSelectionToContext",
          "when": "false"
        },
        {
          "command": "varro.chat.addTerminalSelectionToContext",
          "when": "false"
        }
      ]
    },
    "keybindings": [
      {
        "command": "varro.chat.addToContext",
        "key": "cmd+shift+k",
        "mac": "cmd+shift+k",
        "win": "ctrl+shift+k",
        "linux": "ctrl+shift+k",
        "when": "!terminalFocus"
      },
      {
        "command": "varro.chat.addTerminalSelectionToContext",
        "key": "cmd+shift+k",
        "mac": "cmd+shift+k",
        "win": "ctrl+shift+k",
        "linux": "ctrl+shift+k",
        "when": "terminalFocus"
      }
    ],
    "configuration": {
      "title": "Varro",
      "properties": {
        "varro.server.port": {
          "type": "number",
          "default": 4096,
          "description": "Port for the OpenCode server"
        },
        "varro.server.command": {
          "type": "string",
          "default": "",
          "description": "Optional path to the OpenCode CLI executable used to start the server"
        },
        "varro.server.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the OpenCode server when the extension activates"
        },
        "varro.context.autoAttachFile": {
          "type": "boolean",
          "default": true,
          "description": "Automatically include the active file in live editor context"
        },
        "varro.context.autoAttachSelection": {
          "type": "boolean",
          "default": true,
          "description": "Automatically include the current selection in live editor context"
        },
        "varro.debug.simulateMissingCli": {
          "hidden": true,
          "type": "boolean",
          "default": false,
          "description": "Debug only: make Varro behave as if the OpenCode CLI is not installed"
        },
        "varro.debug.simulateNoProviders": {
          "hidden": true,
          "type": "boolean",
          "default": false,
          "description": "Debug only: make Varro behave as if no providers are configured"
        }
      }
    }
  },
  "scripts": {
    "build:extension": "node esbuild.config.mjs",
    "build:webview": "vite build",
    "build": "npm run build:extension && npm run build:webview",
    "watch:extension": "node esbuild.config.mjs --watch",
    "watch:webview": "vite build --watch",
    "dev": "npm run watch:extension & npm run watch:webview",
    "lint": "oxlint src/ --fix",
    "lint:check": "oxlint src/",
    "fmt": "oxfmt src/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.extension.json && tsc --noEmit -p tsconfig.webview.json",
    "package": "npm run build && npx vsce package --no-dependencies",
    "vscode:install": "npm run package && code --install-extension varro-*.vsix"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.2.4",
    "@types/node": "25.6.0",
    "@types/vscode": "1.91.0",
    "@vitest/coverage-v8": "4.1.5",
    "@vscode/vsce": "3.9.1",
    "esbuild": "0.28.0",
    "jsdom": "29.0.2",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "postcss": "8.5.10",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "vite": "7.3.2",
    "vite-plugin-solid": "2.11.12",
    "vitest": "4.1.5"
  },
  "dependencies": {
    "@opencode-ai/sdk": "1.14.20",
    "marked": "18.0.2",
    "solid-js": "1.9.12"
  }
}
