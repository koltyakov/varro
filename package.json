{
  "name": "varro",
  "displayName": "Varro",
  "description": "OpenCode with real project context, agent control, and sessions that stay with your code.",
  "version": "0.3.0",
  "publisher": "koltyakov",
  "repository": "https://github.com/koltyakov/varro",
  "license": "MIT",
  "engines": {
    "vscode": "^1.91.0"
  },
  "categories": [
    "Chat",
    "Programming Languages",
    "Machine Learning"
  ],
  "keywords": [
    "ai",
    "chat",
    "opencode",
    "agent"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension/extension.js",
  "icon": "assets/icon.png",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "varro",
          "title": "Varro",
          "icon": "assets/icon.png"
        }
      ]
    },
    "views": {
      "varro": [
        {
          "icon": "assets/icon.png",
          "type": "webview",
          "id": "varro.chat",
          "name": "Varro"
        }
      ]
    },
    "commands": [
      {
        "command": "varro.chat.focus",
        "title": "Varro: Focus Chat"
      },
      {
        "command": "varro.chat.newSession",
        "title": "Varro: New Session"
      },
      {
        "command": "varro.chat.addToContext",
        "title": "Varro: Add to Context"
      },
      {
        "command": "varro.chat.addTerminalSelectionToContext",
        "title": "Varro: Add Terminal Selection to Context"
      },
      {
        "command": "varro.chat.abort",
        "title": "Varro: Abort Session"
      },
      {
        "command": "varro.server.restart",
        "title": "Varro: Restart Server"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "varro.chat.addToContext",
          "group": "z_varro"
        }
      ],
      "commandPalette": [
        {
          "command": "varro.chat.addToContext"
        },
        {
          "command": "varro.chat.addTerminalSelectionToContext"
        }
      ]
    },
    "keybindings": [
      {
        "command": "varro.chat.focus",
        "key": "cmd+shift+o",
        "mac": "cmd+shift+o",
        "win": "ctrl+shift+o",
        "linux": "ctrl+shift+o"
      },
      {
        "command": "varro.chat.addToContext",
        "key": "cmd+shift+k",
        "mac": "cmd+shift+k",
        "win": "ctrl+shift+k",
        "linux": "ctrl+shift+k",
        "when": "!terminalFocus"
      },
      {
        "command": "varro.chat.addTerminalSelectionToContext",
        "key": "cmd+shift+k",
        "mac": "cmd+shift+k",
        "win": "ctrl+shift+k",
        "linux": "ctrl+shift+k",
        "when": "terminalFocus"
      }
    ],
    "configuration": {
      "title": "Varro",
      "properties": {
        "varro.server.port": {
          "type": "number",
          "default": 4096,
          "description": "Port for the OpenCode server"
        },
        "varro.server.command": {
          "type": "string",
          "default": "",
          "description": "Optional path to the OpenCode CLI executable used to start the server"
        },
        "varro.server.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the OpenCode server when the extension activates"
        },
        "varro.context.autoAttachFile": {
          "type": "boolean",
          "default": true,
          "description": "Automatically include the active file in live editor context"
        },
        "varro.context.autoAttachSelection": {
          "type": "boolean",
          "default": true,
          "description": "Automatically include the current selection in live editor context"
        },
        "varro.debug.simulateMissingCli": {
          "hidden": true,
          "type": "boolean",
          "default": false,
          "description": "Debug only: make Varro behave as if the OpenCode CLI is not installed"
        },
        "varro.debug.simulateNoProviders": {
          "hidden": true,
          "type": "boolean",
          "default": false,
          "description": "Debug only: make Varro behave as if no providers are configured"
        }
      }
    }
  },
  "scripts": {
    "build:extension": "node esbuild.config.mjs",
    "build:webview": "vite build",
    "build": "npm run build:extension && npm run build:webview",
    "watch:extension": "node esbuild.config.mjs --watch",
    "watch:webview": "vite build --watch",
    "dev": "npm run watch:extension & npm run watch:webview",
    "lint": "oxlint src/ --fix",
    "lint:check": "oxlint src/",
    "fmt": "oxfmt src/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.extension.json && tsc --noEmit -p tsconfig.webview.json",
    "package": "npm run build && npx vsce package",
    "vscode:install": "npm run package && code --install-extension varro-*.vsix"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.91.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vscode/vsce": "^3.9.0",
    "esbuild": "^0.25.0",
    "jsdom": "^26.1.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.4.0",
    "marked": "^15.0.0",
    "solid-js": "^1.9.0"
  }
}
